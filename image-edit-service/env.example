# Qwen-Image-Edit-2511 Service Configuration
# Copy this to .env and adjust as needed

# Server
HOST=0.0.0.0
PORT=8001

# Model - Pre-quantized 4-bit version of Qwen-Image-Edit-2511
MODEL_ID=toandev/Qwen-Image-Edit-2511-4bit

# Generation settings
NUM_INFERENCE_STEPS=40
GUIDANCE_SCALE=1.0
TRUE_CFG_SCALE=4.0

# Memory optimization
ENABLE_CPU_OFFLOAD=true

# Output size - Portrait orientation for mobile
OUTPUT_WIDTH=768
OUTPUT_HEIGHT=1024

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# HuggingFace cache directory (optional)
# CACHE_DIR=/path/to/cache
